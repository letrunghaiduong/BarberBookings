@page
@model BarberBooking.Pages.Booking.CancelModel
@{
    ViewData["Title"] = "Huỷ lịch";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center py-5">
        @if (Model.Success)
        {
            <div class="display-1 text-success mb-3">✅</div>
            <h2>Lịch đã được huỷ thành công</h2>
            <p class="text-muted">Chúng tôi đã gửi email xác nhận tới bạn.</p>
        }
        else if (Model.AlreadyCancelled)
        {
            <div class="display-1 text-warning mb-3">⚠️</div>
            <h2>Lịch này đã được huỷ trước đó</h2>
        }
        else
        {
            <div class="display-1 text-danger mb-3">❌</div>
            <h2>Không tìm thấy lịch hẹn</h2>
            <p class="text-muted">Link huỷ lịch không hợp lệ hoặc đã hết hạn.</p>
        }
        <a href="/" class="btn btn-dark mt-3">Về trang chủ</a>
    </div>
</div>
